{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "Prometheus",
            "description": "Prometheus datasource — URL: http://localhost:9090",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],

    "__requires": [
        { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
        { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
        { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
        { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
        { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
    ],

    "annotations": { "list": [] },
    "description": "SDN Controller Load Balancing — RL Agent Monitoring Dashboard",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
  
    "panels": [
        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
            "id": 100,
            "title": "🖥️ Controller Resources (psutil)",
            "type": "row"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": { "lineWidth": 2, "fillOpacity": 10 },
                    "unit": "percentunit",
                    "min": 0, "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 0.6 },
                            { "color": "red", "value": 0.8 }
                        ]
                    }
                },
                "overrides": []
            },

            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
            "id": 1,
            "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
            
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_cpu_percent",
                    "legendFormat": "Controller {{controller_id}} CPU",
                    "refId": "A"
                }
            ],

            "title": "CPU Usage — mỗi Controller (normalize 0-1)",
            "type": "timeseries"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": { "lineWidth": 2, "fillOpacity": 10 },
                    "unit": "percentunit",
                    "min": 0, "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 0.6 },
                            { "color": "red", "value": 0.75 }
                        ]
                    }
                }
            },
            
            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
            "id": 2,
            "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_ram_percent",
                    "legendFormat": "Controller {{controller_id}} RAM",
                    "refId": "A"
                }
            ],

            "title": "RAM Usage — mỗi Controller (normalize 0-1)",
            "type": "timeseries"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": { "lineWidth": 2, "fillOpacity": 10 },
                    "unit": "short",
                    "min": 0
                }
            },

            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
            "id": 3,
            "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_packet_in_rate",
                    "legendFormat": "Controller {{controller_id}} Packet-in Rate",
                    "refId": "A"
                }
            ],

            "title": "Packet-In Rate — mỗi Controller (normalize 0-1)",
            "type": "timeseries"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": { "lineWidth": 2 },
                    "unit": "short",
                    "min": 0
                }
            },

            "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
            "id": 4,
            "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_switch_count",
                    "legendFormat": "Controller {{controller_id}} Switches",
                    "refId": "A"
                }
            ],

            "title": "Switch Count — mỗi Controller",
            "type": "timeseries"
        },

        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
            "id": 101,
            "title": "🤖 RL Agent Metrics",
            "type": "row"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "palette-classic" },
                    "custom": { "lineWidth": 2, "fillOpacity": 5 },
                    "unit": "short"
                }
            },

            "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
            "id": 5,
            "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_rl_reward",
                    "legendFormat": "RL Reward (per step)",
                    "refId": "A"
                }
            ],

            "title": "RL Agent — Reward theo thời gian",
            "type": "timeseries"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "unit": "short",
                    "min": 0, "max": 0.5,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 0.05 },
                            { "color": "red", "value": 0.15 }
                        ]
                    }
                }
            },

            "gridPos": { "h": 8, "w": 6, "x": 12, "y": 18 },
            "id": 6,
            "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true },

            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_rl_variance_cpu",
                    "legendFormat": "CPU Variance",
                    "refId": "A"
                }
            ],

            "title": "CPU Variance (mục tiêu < 0.02)",
            "type": "gauge"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "green", "value": null },
                            { "color": "yellow", "value": 5 },
                            { "color": "red", "value": 15 }
                        ]
                    }
                }
            },

            "gridPos": { "h": 8, "w": 6, "x": 18, "y": 18 },
            "id": 7,
            "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },

            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_rl_migration_count",
                    "legendFormat": "Migrations",
                    "refId": "A"
                }
            ],

            "title": "Migration Count (episode hiện tại)",
            "type": "stat"
        },

        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
            "id": 102,
            "title": "📊 Cluster Health",
            "type": "row"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "mappings": [
                        { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
                    ],
                    "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
                    "unit": "short"
                }
            },

            "gridPos": { "h": 4, "w": 8, "x": 0, "y": 27 },
            "id": 8,
            "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },

            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_controller_up{controller_id=\"1\"}",
                    "legendFormat": "Controller 1",
                    "refId": "A"
                }
            ],

            "title": "Controller 1 Status",
            "type": "stat"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },

            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "mappings": [
                        { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
                    ],
                    
                    "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
                    "unit": "short"
                }
            },

            "gridPos": { "h": 4, "w": 8, "x": 8, "y": 27 },
            "id": 9,
            "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },

            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_controller_up{controller_id=\"2\"}",
                    "legendFormat": "Controller 2",
                    "refId": "A"
                }
            ],

            "title": "Controller 2 Status",
            "type": "stat"
        },

        {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "mappings": [
                        { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
                    ],
                    "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
                    "unit": "short"
                }
            },

            "gridPos": { "h": 4, "w": 8, "x": 16, "y": 27 },
            "id": 10,
            "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
            "targets": [
                {
                    "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
                    "expr": "sdn_controller_up{controller_id=\"3\"}",
                    "legendFormat": "Controller 3",
                    "refId": "A"
                }
            ],

            "title": "Controller 3 Status",
            "type": "stat"
        }
    ],

    "refresh": "5s",
    "schemaVersion": 38,
    "style": "dark",
    "tags": ["sdn", "reinforcement-learning", "load-balancing"],
    "templating": { "list": [] },
    "time": { "from": "now-15m", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "SDN RL Load Balancer",
    "uid": "sdn-rl-dashboard-v1",
    "version": 1
}